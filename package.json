{
  "name": "pulapay",
  "version": "0.1.0",
  "private": true,
  "description": "Universal financial account for West Africa",
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:migrate": "pnpm --filter @pulapay/database migrate:dev",
    "db:migrate:prod": "pnpm --filter @pulapay/database migrate:deploy",
    "db:seed": "pnpm --filter @pulapay/database seed",
    "db:studio": "pnpm --filter @pulapay/database studio",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
