# ─── APPLICATION ──────────────────────────────────────────────
NODE_ENV=development
APP_NAME=Pulapay
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ─── DATABASE ─────────────────────────────────────────────────
DATABASE_URL=postgresql://pulapay:password@localhost:5432/pulapay_dev

# ─── REDIS ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT AUTH ─────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-256-bit-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-in-production-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

# ─── PRIVY (AUTH) ─────────────────────────────────────────────
PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# ─── TWILIO (SMS/WHATSAPP OTP) ────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# ─── MOBILE MONEY — MTN MOMO ──────────────────────────────────
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_API_KEY=your-mtn-api-key
MTN_MOMO_API_USER=your-mtn-api-user
MTN_MOMO_API_SECRET=your-mtn-api-secret
MTN_MOMO_SUBSCRIPTION_KEY=your-mtn-subscription-key
MTN_MOMO_ENVIRONMENT=sandbox

# ─── MOBILE MONEY — MOOV ──────────────────────────────────────
MOOV_API_KEY=your-moov-api-key
MOOV_API_SECRET=your-moov-api-secret
MOOV_ENVIRONMENT=sandbox

# ─── MOBILE MONEY — CELTIIS ───────────────────────────────────
CELTIIS_API_KEY=your-celtiis-api-key
CELTIIS_API_SECRET=your-celtiis-api-secret

# ─── USDC / CIRCLE ────────────────────────────────────────────
CIRCLE_API_KEY=your-circle-api-key
CIRCLE_ENVIRONMENT=sandbox
TRON_NETWORK=shasta
ETHEREUM_NETWORK=sepolia

# ─── MPC WALLET ───────────────────────────────────────────────
MPC_PROVIDER=web3auth
WEB3AUTH_CLIENT_ID=your-web3auth-client-id
WEB3AUTH_NETWORK=testnet

# ─── COMPLIANCE ───────────────────────────────────────────────
SMILE_IDENTITY_PARTNER_ID=your-smile-identity-partner-id
SMILE_IDENTITY_API_KEY=your-smile-identity-api-key
CHAINALYSIS_API_KEY=your-chainalysis-api-key
COMPLY_ADVANTAGE_API_KEY=your-comply-advantage-api-key

# ─── MONITORING ───────────────────────────────────────────────
SENTRY_DSN=your-sentry-dsn
DATADOG_API_KEY=your-datadog-api-key

# ─── AWS ──────────────────────────────────────────────────────
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=pulapay-uploads
